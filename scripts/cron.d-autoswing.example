# autoswing brain — each window fires at both EDT and EST UTC times;
# scripts/brain_run.sh's ET guard skips the off-target instance.
0  12 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh premarket
0  13 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh premarket
0  14 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh entry
0  15 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh entry
30 16 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh midday
30 17 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh midday
30 19 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh preclose
30 20 * * 1-5 supper-user /home/supper-user/autoswing/scripts/brain_run.sh preclose
# ramp-up healthcheck: hourly at :45, deterministic, no LLM. Avoids the
# gateway's nightly restart window; shares the brain lock.
45 10-22 * * 1-5 supper-user /home/supper-user/autoswing/scripts/healthcheck.sh
# daily manager/dev review + owner email, after preclose in both DST regimes
15 21 * * 1-5 supper-user /home/supper-user/autoswing/scripts/manager_run.sh
# nightly offsite backup (quiet hours, after gateway nightly restart)
10 5 * * * supper-user /home/supper-user/autoswing/scripts/backup.sh
